generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SECURITY
  TEACHER
  STUDENT
  VISITOR
}

enum Zone {
  A
  B
  C
  D
}

enum SpaceType {
  STANDARD
  VIP
  HANDICAPPED
  ELECTRIC
  RESERVED
  TEACHER
}

enum SpaceStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  QR_CODE
  MOBILE
}

enum EntryMethod {
  QR
  PLATE
  NFC
  MANUAL
  VISITOR_QR
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  USED
}

enum ReservationType {
  STANDARD
  PERSONAL
  EVENT
  SPECIAL_VISIT
}

enum NotificationType {
  PARKING_FULL
  VISITOR_EXPIRING
  OVERSTAY
  INVALID_ACCESS
  PAYMENT_REQUIRED
  RESERVATION_EXPIRING
  BARRIER_ACTION
  SYSTEM_ALERT
  BLACKLIST
  INFO
}

enum BarrierAction {
  OPEN
  CLOSE
  BLOCK
  ERROR
}

enum TriggerSource {
  QR
  PLATE
  NFC
  MANUAL
  SYSTEM
  PAYMENT
}

enum Orientation {
  HORIZONTAL
  DIAGONAL
  VERTICAL
}

model Campus {
  id           String   @id @default(uuid())
  name         String
  address      String
  lat          Float
  lng          Float
  zoom         Int      @default(18)
  total_spaces Int      @default(500)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  spaces  ParkingSpace[]
  cameras Camera[]
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  role          Role      @default(STUDENT)
  first_name    String
  last_name     String
  phone         String?
  carnet        String?   @unique
  nfc_card_id   String?   @unique
  qr_code       String    @unique
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  vehicles              Vehicle[]
  sessions              ParkingSession[]
  payments              Payment[]
  reservations          Reservation[]
  notifications         Notification[]
  audit_logs            AuditLog[]
  visitor_qrs           VisitorQR[]          @relation("GeneratedBy")
  blacklists_added      Blacklist[]          @relation("AddedBy")
  blacklists_removed    Blacklist[]          @relation("RemovedBy")
  barrier_logs          BarrierLog[]
  subscriptions         ParkingSubscription[]
  events_created        ParkingEvent[]
  monthly_bills         MonthlyBill[]
  card_replacements     CardReplacement[]    @relation("CardUser")
  card_replacements_processed CardReplacement[] @relation("CardProcessor")

  @@index([email])
  @@index([role])
}

model Vehicle {
  id               String    @id @default(uuid())
  user_id          String
  placa            String    @unique
  brand            String?
  model            String?
  color            String?
  year             Int?
  is_authorized    Boolean   @default(true)
  blacklisted      Boolean   @default(false)
  blacklist_reason String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  user              User             @relation(fields: [user_id], references: [id])
  sessions          ParkingSession[]
  reservations      Reservation[]
  blacklist_entries Blacklist[]

  @@index([placa])
  @@index([user_id])
  @@index([blacklisted])
}

model ParkingSpace {
  id                String      @id @default(uuid())
  code              String      @unique
  campus_id         String
  zone              Zone
  floor             Int         @default(0)
  type              SpaceType   @default(STANDARD)
  status            SpaceStatus @default(AVAILABLE)
  is_active         Boolean     @default(true)
  lat               Float?
  lng               Float?
  last_sensor_update DateTime?
  created_at        DateTime    @default(now())
  updated_at        DateTime    @updatedAt

  campus       Campus           @relation(fields: [campus_id], references: [id])
  sessions     ParkingSession[]
  reservations Reservation[]

  @@index([status])
  @@index([zone])
  @@index([campus_id])
}

model ParkingSession {
  id               String        @id @default(uuid())
  vehicle_id       String
  space_id         String
  user_id          String?
  entry_time       DateTime      @default(now())
  exit_time        DateTime?
  entry_method     EntryMethod   @default(MANUAL)
  status           SessionStatus @default(ACTIVE)
  duration_minutes Int?
  amount_due       Float?
  is_paid          Boolean       @default(false)
  operator_entry_id String?
  operator_exit_id  String?
  notes            String?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  vehicle  Vehicle      @relation(fields: [vehicle_id], references: [id])
  space    ParkingSpace @relation(fields: [space_id], references: [id])
  user     User?        @relation(fields: [user_id], references: [id])
  payment  Payment?
  visitor_qr VisitorQR?

  @@index([status])
  @@index([vehicle_id])
  @@index([entry_time])
}

model Payment {
  id                    String        @id @default(uuid())
  session_id            String        @unique
  user_id               String
  amount                Float
  payment_method        PaymentMethod @default(CASH)
  status                PaymentStatus @default(PENDING)
  transaction_reference String?
  paid_at               DateTime?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  session ParkingSession @relation(fields: [session_id], references: [id])
  user    User           @relation(fields: [user_id], references: [id])
}

model Reservation {
  id         String            @id @default(uuid())
  user_id    String
  vehicle_id String?
  space_id   String
  start_time DateTime
  end_time   DateTime
  status     ReservationStatus @default(CONFIRMED)
  type       ReservationType   @default(STANDARD)
  notes      String?
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt

  user    User         @relation(fields: [user_id], references: [id])
  space   ParkingSpace @relation(fields: [space_id], references: [id])
  vehicle Vehicle?     @relation(fields: [vehicle_id], references: [id])

  @@index([status])
  @@index([user_id])
  @@index([start_time])
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String?
  type       NotificationType
  title      String
  message    String
  is_read    Boolean          @default(false)
  read_at    DateTime?
  metadata   Json?
  created_at DateTime         @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([is_read])
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  resource    String?
  resource_id String?
  metadata    Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([action])
  @@index([created_at])
}

model Blacklist {
  id                 String    @id @default(uuid())
  vehicle_id         String
  reason             String
  added_by_user_id   String
  is_active          Boolean   @default(true)
  removed_at         DateTime?
  removed_by_user_id String?
  created_at         DateTime  @default(now())

  vehicle    Vehicle @relation(fields: [vehicle_id], references: [id])
  added_by   User    @relation("AddedBy", fields: [added_by_user_id], references: [id])
  removed_by User?   @relation("RemovedBy", fields: [removed_by_user_id], references: [id])

  @@index([is_active])
  @@index([vehicle_id])
}

model BarrierLog {
  id             String        @id @default(uuid())
  barrier_id     String
  action         BarrierAction
  trigger_source TriggerSource @default(MANUAL)
  operator_id    String?
  session_id     String?
  notes          String?
  created_at     DateTime      @default(now())

  operator User? @relation(fields: [operator_id], references: [id])

  @@index([barrier_id])
  @@index([created_at])
}

model VisitorQR {
  id                   String    @id @default(uuid())
  qr_code              String    @unique
  generated_by_user_id String
  visitor_name         String
  vehicle_plate        String
  purpose              String?
  expires_at           DateTime
  is_used              Boolean   @default(false)
  used_at              DateTime?
  session_id           String?   @unique
  created_at           DateTime  @default(now())

  generated_by User           @relation("GeneratedBy", fields: [generated_by_user_id], references: [id])
  session      ParkingSession? @relation(fields: [session_id], references: [id])

  @@index([qr_code])
  @@index([expires_at])
}

model Camera {
  id         String   @id @default(uuid())
  name       String
  location   String
  stream_url String?
  has_lpr    Boolean  @default(false)
  is_active  Boolean  @default(true)
  lat        Float?
  lng        Float?
  campus_id  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  campus Campus? @relation(fields: [campus_id], references: [id])
}

// ── TariffConfig — tarifas editables por rol ─────────────────────────────────

model TariffConfig {
  id                   String   @id @default(uuid())
  role                 Role     @unique
  hourly_rate          Decimal  @default(0) @db.Decimal(10, 2)
  is_free              Boolean  @default(false)
  max_free_hours       Int?
  updated_at           DateTime @updatedAt
  updated_by_user_id   String?
}

// ── Nuevos modelos — Tarea 1 ──────────────────────────────────────────────────

enum SubscriptionType {
  MONTHLY
  SEMESTER
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum TariffMode {
  HOURLY
  FLAT_RATE
}

enum EventStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum BillStatus {
  OPEN
  CLOSED
  PAID
  OVERDUE
}

enum ReplacementReason {
  LOST
  DAMAGED
  STOLEN
  REASSIGNMENT
}

model ParkingSubscription {
  id                 String             @id @default(uuid())
  user_id            String
  type               SubscriptionType
  status             SubscriptionStatus @default(ACTIVE)
  start_date         DateTime
  end_date           DateTime
  amount_paid        Decimal            @db.Decimal(10, 2)
  payment_reference  String?
  auto_renew         Boolean            @default(false)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([status])
  @@index([end_date])
}

model ParkingEvent {
  id                    String      @id @default(uuid())
  name                  String
  description           String?
  event_date            DateTime
  start_time            DateTime
  end_time              DateTime
  tariff_mode           TariffMode  @default(HOURLY)
  flat_rate             Decimal?    @db.Decimal(10, 2)
  affected_zones        String
  status                EventStatus @default(SCHEDULED)
  created_by_user_id    String
  notes                 String?
  uses_external_parking Boolean     @default(false)
  external_parking_name String?
  shuttle_available     Boolean     @default(false)
  capacity_override     Int?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  created_by User @relation(fields: [created_by_user_id], references: [id])

  @@index([event_date])
  @@index([status])
}

model MonthlyBill {
  id                String     @id @default(uuid())
  user_id           String
  month             Int
  year              Int
  total_sessions    Int        @default(0)
  total_minutes     Int        @default(0)
  total_amount      Decimal    @default(0) @db.Decimal(10, 2)
  status            BillStatus @default(OPEN)
  due_date          DateTime
  paid_at           DateTime?
  payment_reference String?
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@unique([user_id, month, year])
  @@index([user_id])
  @@index([month, year])
  @@index([status])
}

model CardReplacement {
  id                  String            @id @default(uuid())
  user_id             String
  old_nfc_token       String?
  new_nfc_token       String?
  reason              ReplacementReason
  replacement_fee     Decimal           @default(50.00) @db.Decimal(10, 2)
  fee_paid            Boolean           @default(false)
  requested_at        DateTime          @default(now())
  processed_at        DateTime?
  processed_by_user_id String?
  notes               String?
  created_at          DateTime          @default(now())

  user         User  @relation("CardUser", fields: [user_id], references: [id])
  processed_by User? @relation("CardProcessor", fields: [processed_by_user_id], references: [id])
}
